rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // user_data koleksiyonuna okuma ve yazma izni
    match /user_data/{document} {
      allow read, write: if request.auth != null;
    }
    
    // leaderboard koleksiyonuna okuma ve yazma izni (herkese açık)
    match /leaderboard/{document} {
      allow read, write: if request.auth != null;
    }
    
    // active_users koleksiyonuna okuma ve yazma izni
    match /active_users/{document} {
      allow read, write: if request.auth != null;
    }
    
    // Diğer tüm koleksiyonları dış dünyaya kapat
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
