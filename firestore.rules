rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // user_data koleksiyonuna herkes okuyabilir (rakip analizi için), ancak sadece sahibi yazabilir
    match /user_data/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // YENİ: user_denemeler koleksiyonu - Deneme Merkezi verileri için tamamen izole tablo
    match /user_denemeler/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // leaderboard koleksiyonu herkes (üye olanlar) tarafından okunabilir, ancak yazma/güncelleme sadece kullanıcının kendi verisi için yapılabilir
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // branch_leaderboards koleksiyonu herkes tarafından okunabilir, yazma kullanıcının kendisine ait belge için olabilir
    // Belge ID'si "userId_subjectId" formatında olduğu için userId'nin document adının başında olup olmadığını kontrol ediyoruz
    match /branch_leaderboards/{documentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == documentId.split('_')[0];
    }
    
    // active_users koleksiyonuna sadece veri sahibinin yazıp okumasına izin ver (Başkalarının listesini çekmek için tüm kullanıcıları okumaya izin vermemiz gerekir mi? Evet, getOnlineUsersCount için genel okuma izni gerekir)
    match /active_users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Diğer tüm koleksiyonları dış dünyaya kapat
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
