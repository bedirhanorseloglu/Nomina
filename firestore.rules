rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Sadece user_data koleksiyonuna okuma ve yazma izni ver (Süresiz)
    match /user_data/{document} {
      allow read, write: if true;
    }
    
    // Diğer tüm koleksiyonları dış dünyaya kapat
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
